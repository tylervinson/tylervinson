{
  "manifest_version": 3,
  "name": "Sitecore Widget Editor",
  "version": "3.1.0",
  "description": "Edit Sitecore widget content directly from the Content Editor via the browser sidebar",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Sitecore Widget Editor",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "sitecore-bridge.js",
        "content-script.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "sitecore-bridge.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}