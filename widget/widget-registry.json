{
  "version": "1.4.0",
  "updatedAt": "2026-03-03T00:00:00.000Z",
  "downloadUrl": "https://www.tylervinson.com/widget/",
  "widgets": [
    {
      "class": "card-row",
      "name": "Animated Cards",
      "desc": "Three-card stat widget with animated number counters",
      "repeat": {
        "selector": ".profile-card",
        "groupLabel": "Card"
      },
      "fields": [
        {
          "key": "number",
          "label": "Number",
          "selector": ".number",
          "type": "text",
          "syncDataAttr": "data-target",
          "syncNumeric": true
        },
        {
          "key": "label",
          "label": "Label",
          "selector": ".copy-text",
          "type": "text"
        }
      ],
      "standaloneFields": []
    },
    {
      "class": "insurance-comparison-tool",
      "name": "Insurance Plan Comparison",
      "desc": "Compare up to 4 insurance plans side-by-side",
      "repeat": {
        "selector": ".plan-button",
        "groupLabel": "Plan",
        "groupLabelField": "name"
      },
      "fields": [
        {
          "key": "name",
          "label": "Plan Name",
          "selector": ".plan-button-name",
          "type": "text",
          "syncDataAttr": "data-plan-name"
        },
        {
          "key": "coverage",
          "label": "Coverage Label",
          "selector": ".plan-button-coverage",
          "type": "text"
        },
        {
          "key": "price",
          "label": "Monthly Price",
          "selector": ".plan-button-price",
          "type": "text",
          "syncDataAttr": "data-price",
          "syncNumeric": true,
          "gridSelector": "[data-comparison='price']",
          "gridCellSelector": "[data-plan='{planNum}']"
        },
        {
          "key": "deductible",
          "label": "Annual Deductible",
          "gridSelector": "[data-comparison='deductible']",
          "gridCellSelector": "[data-plan='{planNum}']",
          "syncDataAttr": "data-deductible",
          "syncNumeric": true,
          "type": "text"
        },
        {
          "key": "maxOutOfPocket",
          "label": "Max Out-of-Pocket",
          "gridSelector": "[data-comparison='maxOutOfPocket']",
          "gridCellSelector": "[data-plan='{planNum}']",
          "syncDataAttr": "data-max-out-of-pocket",
          "syncNumeric": true,
          "type": "text"
        },
        {
          "key": "coveragePercent",
          "label": "Coverage %",
          "gridSelector": "[data-comparison='coveragePercent']",
          "gridCellSelector": "[data-plan='{planNum}']",
          "syncDataAttr": "data-coverage-percent",
          "syncNumeric": true,
          "type": "text"
        },
        {
          "key": "doctorVisits",
          "label": "Doctor Visit Copay",
          "gridSelector": "[data-comparison='doctorVisits']",
          "gridCellSelector": "[data-plan='{planNum}']",
          "syncDataAttr": "data-doctor-visits",
          "syncNumeric": true,
          "type": "text"
        },
        {
          "key": "prescription",
          "label": "Prescription Coverage",
          "gridSelector": "[data-comparison='prescription']",
          "gridCellSelector": "[data-plan='{planNum}']",
          "type": "text"
        },
        {
          "key": "emergency",
          "label": "Emergency Care Copay",
          "gridSelector": "[data-comparison='emergency']",
          "gridCellSelector": "[data-plan='{planNum}']",
          "syncDataAttr": "data-emergency",
          "syncNumeric": true,
          "type": "text"
        },
        {
          "key": "mentalHealth",
          "label": "Mental Health Coverage",
          "gridSelector": "[data-comparison='mentalHealth']",
          "gridCellSelector": "[data-plan='{planNum}']",
          "type": "text"
        },
        {
          "key": "dentalVision",
          "label": "Dental / Vision",
          "gridSelector": "[data-comparison='dentalVision']",
          "gridCellSelector": "[data-plan='{planNum}']",
          "type": "text"
        }
      ],
      "standaloneFields": [
        {
          "key": "title",
          "label": "Title",
          "selector": "h1",
          "type": "text"
        },
        {
          "key": "subtitle",
          "label": "Subtitle",
          "selector": ".subtitle",
          "type": "text"
        },
        {
          "key": "instructionHeading",
          "label": "Instruction Heading",
          "selector": ".instruction-content h2",
          "type": "text"
        },
        {
          "key": "instructionBody",
          "label": "Instruction Body",
          "selector": ".instruction-content p",
          "type": "textarea"
        }
      ]
    },
    {
      "class": "zoom-meetings",
      "name": "Zoom Meetings",
      "desc": "Styled Zoom meeting list with automatic expiry and sorting",
      "repeat": {
        "selector": ".zoom-meeting",
        "groupLabel": "Meeting",
        "groupLabelField": "title"
      },
      "fields": [
        {
          "key": "title",
          "label": "Meeting Title",
          "selector": ".zoom-title",
          "type": "text"
        },
        {
          "key": "description",
          "label": "Description",
          "selector": ".zoom-description",
          "type": "textarea"
        },
        {
          "key": "link",
          "label": "Zoom URL",
          "selector": ".zoom-link",
          "type": "text",
          "syncDataAttr": "href"
        },
        {
          "key": "start",
          "label": "Start Date/Time (ISO)",
          "selector": ".zoom-meeting",
          "type": "text",
          "syncDataAttr": "data-start"
        },
        {
          "key": "end",
          "label": "End Date/Time (ISO)",
          "selector": ".zoom-meeting",
          "type": "text",
          "syncDataAttr": "data-end"
        }
      ],
      "standaloneFields": []
    }
  ]
}