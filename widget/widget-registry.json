        },
        {
          "key": "title",
          "label": "Meeting Title",
          "selector": ".zmw-title-text",
          "type": "text"
        },
        {
          "key": "description",
          "label": "Short Description",
          "selector": ".zmw-description",
          "type": "text"
        },
        {
          "key": "registerUrl",
          "label": "Registration URL",
          "type": "url",
          "attr": "data-register-url",
          "hint": "Full external URL (https://...). Leave blank to hide the Register button."
        },
        {
          "key": "details",
          "label": "Detail Body",
          "selector": ".zmw-extender",
          "type": "richtext"
        }
      ]
