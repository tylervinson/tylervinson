    {
      "class": "zoom-meetings",
      "name": "Zoom Meetings",
      "repeat": {
        "selector": ".zmw-meeting",
        "groupLabel": "Meeting",
        "groupLabelField": "title",
        "dateField": "datetime",
        "dateAttr": "data-end",
